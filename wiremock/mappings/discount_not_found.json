{
  "request": {
    "method": "GET",
    "urlPath": "/discount",
    "queryParameters": {
      "productId": {
        "equalTo": "999"
      }
    }
  },
  "response": {
    "status": 404,
    "headers": {
      "Content-Type": "application/problem+json"
    },
    "jsonBody": {
      "type": "https://tools.ietf.org/html/rfc7231#section-6.5.4",
      "title": "Not Found",
      "status": 404,
      "detail": "No discount configuration found for the given productId.",
      "instance": "/discount"
    }
  }
}
